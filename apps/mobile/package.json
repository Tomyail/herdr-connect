{
  "name": "@herdr-connect/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo prebuild --platform ios --no-install && expo run:ios --device",
    "release:ios:prepare": "node scripts/ios-release.mjs prepare",
    "release:ios:build": "node scripts/ios-release.mjs build",
    "release:ios:upload": "node scripts/ios-release.mjs upload",
    "release:ios:distribute": "node scripts/ios-release.mjs distribute",
    "release:android": "scripts/android-release.sh",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts src/i18n/*.test.ts src/notifications/*.test.ts src/theme/*.test.ts",
    "config": "expo config --type public"
  },
  "dependencies": {
    "@dawidzawada/bonjour-zeroconf": "2.2.0",
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.18.10",
    "@react-navigation/elements": "^2.9.32",
    "@react-navigation/native": "^7.3.10",
    "@react-navigation/native-stack": "^7.18.2",
    "expo": "~56.0.16",
    "expo-audio": "~56.0.12",
    "expo-camera": "~56.0.8",
    "expo-dev-client": "~56.0.23",
    "expo-localization": "~56.0.6",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "pinned-fetch": "file:./modules/pinned-fetch",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-mmkv": "^4.3.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "~19.2.2",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2"
  }
}
