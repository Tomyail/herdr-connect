{
  "name": "@herdr-connect/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo prebuild --platform ios --no-install && expo run:ios --device",
    "release:ios:prepare": "node scripts/ios-release.mjs prepare",
    "release:ios:build": "node scripts/ios-release.mjs build",
    "release:ios:upload": "node scripts/ios-release.mjs upload",
    "release:ios:distribute": "node scripts/ios-release.mjs distribute",
    "release:android": "scripts/android-release.sh",
    "typecheck": "tsc --noEmit",
    "config": "expo config --type public"
  },
  "dependencies": {
    "@inthepocket/react-native-service-discovery": "0.2.9",
    "expo": "~56.0.16",
    "expo-dev-client": "~56.0.23",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.2"
  }
}
